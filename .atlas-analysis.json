  "keyFeatures": [
    "Type-safe URL query string state management",
    "Built-in parsers for common data types",
    "Framework adapters for Next.js, React, Remix, React Router, and TanStack Router",
    "Server-side rendering support with search params cache",
    "Automatic batching and throttling of URL updates",
    "Testing utilities for unit testing components",
    "Support for transitions and loading states",
    "Custom parser creation with builder pattern",
    "Minimal bundle size (4.5 kB tree-shaken)"
  ],
